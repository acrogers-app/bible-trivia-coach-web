# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local/generated artifacts (keep out of Git)
generated/
generated_mark_1.json

# macOS resource fork files
._*

# JSON backups/snapshots
public/data/*.before-*.json

# Local /play page snapshots
src/app/play/page.*.tsx
src/app/play/*.backup.tsx
play_backups/

# Python virtual environment
.venv/

# Backup files (all patterns)
*.bak.*
*.bak

# Generated script reports / checkpoints
scripts/phase1_checkpoint.json
scripts/phase1_gaps.json
scripts/phase1_generated.json
scripts/phase1_manual_refs.json
scripts/phase1_merge_report.json
scripts/structural_removed.json

# One-time patch scripts (keep source, not patches)
scripts/patch_*.mjs
scripts/fix_*.mjs
scripts/repair_*.mjs
scripts/remove_*.mjs
scripts/add_*.mjs
scripts/ensure_*.mjs

# Python fix scripts
scripts/fix_*.py
